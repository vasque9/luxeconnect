generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROVIDER
  CLIENT
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PromotionType {
  FEATURED_HOME
  TOP_SEARCH
  HIGHLIGHTED
}

enum PromotionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTIONED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String?
  passwordHash  String
  role          Role      @default(CLIENT)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  ageVerified   Boolean   @default(false)
  kycDocumentUrl String?
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       ProviderProfile?
  favorites     Favorite[]
  reviews       Review[]         @relation("ReviewAuthor")
  reports       Report[]         @relation("ReportAuthor")
  payments      Payment[]
  sessions      Session[]
  auditLogs     AuditLog[]       @relation("AuditUser")
  notifications Notification[]

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model ProviderProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alias        String
  bio          String?  @db.Text
  cityId       String
  city         City     @relation(fields: [cityId], references: [id])
  latitude     Float?
  longitude    Float?
  pricePerHour Int
  availability String?
  languages    String[]
  isOnline     Boolean  @default(false)
  viewCount    Int      @default(0)
  contactCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing    Listing?
  images     ProfileImage[]
  services   ProfileService[]
  reviews    Review[]
  promotions Promotion[]

  @@index([cityId])
  @@index([pricePerHour])
}

model ProfileImage {
  id        String          @id @default(uuid())
  profileId String
  profile   ProviderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url       String
  s3Key     String
  order     Int             @default(0)
  isBlurred Boolean         @default(true)
  approved  Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@index([profileId])
}

model ProfileService {
  id        String          @id @default(uuid())
  profileId String
  profile   ProviderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service         @relation(fields: [serviceId], references: [id])

  @@unique([profileId, serviceId])
}

model Listing {
  id           String        @id @default(uuid())
  profileId    String        @unique
  profile      ProviderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String
  description  String        @db.Text
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  status       ListingStatus @default(PENDING)
  rejectReason String?
  publishedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  revisions ListingRevision[]
  reports   Report[]

  @@index([status])
  @@index([categoryId])
  @@index([publishedAt])
}

model ListingRevision {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  snapshot  Json
  changedBy String
  reason    String?
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  order    Int       @default(0)
  listings Listing[]
}

model Service {
  id       String           @id @default(uuid())
  name     String           @unique
  slug     String           @unique
  profiles ProfileService[]
}

model City {
  id       String            @id @default(uuid())
  name     String            @unique
  slug     String            @unique
  region   String?
  profiles ProviderProfile[]
}

model Review {
  id        String          @id @default(uuid())
  profileId String
  profile   ProviderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  authorId  String
  author    User            @relation("ReviewAuthor", fields: [authorId], references: [id])
  rating    Int
  comment   String?         @db.Text
  approved  Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@unique([profileId, authorId])
  @@index([profileId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  createdAt DateTime @default(now())

  @@unique([userId, profileId])
  @@index([userId])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  stripePaymentId String?  @unique
  stripeSessionId String?
  amount          Int
  currency        String   @default("EUR")
  description     String?
  metadata        Json?
  paid            Boolean  @default(false)
  createdAt       DateTime @default(now())

  promotion Promotion?

  @@index([userId])
}

model Promotion {
  id        String          @id @default(uuid())
  profileId String
  profile   ProviderProfile @relation(fields: [profileId], references: [id])
  paymentId String          @unique
  payment   Payment         @relation(fields: [paymentId], references: [id])
  type      PromotionType
  status    PromotionStatus @default(ACTIVE)
  startsAt  DateTime        @default(now())
  endsAt    DateTime
  createdAt DateTime        @default(now())

  @@index([profileId])
  @@index([status, endsAt])
}

model PromotionPricing {
  id       String        @id @default(uuid())
  type     PromotionType @unique
  name     String
  priceEur Int
  duration Int
}

model Report {
  id          String       @id @default(uuid())
  listingId   String
  listing     Listing      @relation(fields: [listingId], references: [id])
  reporterId  String
  reporter    User         @relation("ReportAuthor", fields: [reporterId], references: [id])
  reason      String
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewNotes String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([listingId])
  @@index([status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation("AuditUser", fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
